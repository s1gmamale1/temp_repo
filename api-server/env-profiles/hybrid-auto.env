# Hybrid-auto profile — prefers Ollama, falls back to OpenRouter when needed
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
DB_PATH=./data/project-claw.db
DB_TYPE=sqlite

AI_PROVIDER=auto
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_PM=qwen2.5-coder:7b
OLLAMA_MODEL_RND=qwen2.5-coder:7b
OLLAMA_MODEL_WORKER=qwen2.5-coder:7b

# Add your OpenRouter key to enable cloud fallback:
# OPENROUTER_API_KEY=sk-or-...
